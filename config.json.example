{
  "vaults": [
    {
      "name": "HYPERPC Main",
      "path": "C:\\Users\\HYPERPC\\Documents\\mz-0",
      "role": "personal",
      "inbox_path": "00 - Inbox",
      "areas_path": "02 - Areas",
      "resources_path": "03 - Resources",
      "archive_path": "04 - Archieve",
      "voice_dialogues_path": "02 - Areas/Дневники/Голосовые диалоги",
      "templates_path": "99 - Templates"
    }
  ],
  "obsidian": {
    "rest_api_url": "http://localhost:27123",
    "api_key": "YOUR_API_KEY_HERE",
    "timeout": 10
  },
  "kimi": {
    "cli_path": "kimi",
    "use_cli": false,
    "timeout": 60
  },
  "ollama": {
    "url": "http://localhost:11434",
    "model": "qwen3:8b",
    "enabled": true
  },
  "claude": {
    "api_key": "YOUR_API_KEY_HERE",
    "model": "claude-sonnet-4-20250514",
    "enabled": false
  },
  "hf": {
    "api_key": "YOUR_API_KEY_HERE",
    "model": "Qwen/Qwen2.5-7B-Instruct",
    "enabled": false,
    "use_local": false,
    "local_model_path": ""
  },
  "wavespeed": {
    "api_key": "YOUR_API_KEY_HERE",
    "model": "openai/gpt-5.4",
    "url": "https://llm.wavespeed.ai/v1",
    "enabled": true
  },
  "speech": {
    "engine": "vosk",
    "vosk_model_path": "models/vosk-model-small-ru-0.22",
    "whisper_api_key": "YOUR_API_KEY_HERE",
    "whisper_model": "whisper-1",
    "language": "ru",
    "sample_rate": 16000
  },
  "tts": {
    "engine": "edge-tts",
    "voice": "ru-RU-SvetlanaNeural",
    "rate": "+0%",
    "volume": "+0%"
  },
  "app": {
    "log_dir": "logs",
    "session_log": true,
    "auto_save": true,
    "playback_after_response": true,
    "cognition_priority": ["wavespeed", "ollama"],
    "auto_model": {
      "enabled": true,
      "auto_discover": true,
      "auto_benchmark": true,
      "benchmark_interval_hours": 24,
      "prefer_free": false,
      "prefer_fast": false,
      "max_latency_ms": 5000,
      "min_quality_score": 5.0
    }
  }
}
